# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-key-here

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-key-here

# Auth0 (set AUTH_ENABLED=true when ready)
AUTH_ENABLED=false
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://autopdf2sqlizer.pisteyo.com/api

# GitHub (for Wiggum loop triggering)
GITHUB_PAT=ghp_your-personal-access-token
GITHUB_REPO=gavinpisteyo/autoPDF2SQLizer

# Azure SQL Server (admin connection for per-org database provisioning)
# When absent, SQLite is used (local dev mode)
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_ADMIN_USER=sqladmin
AZURE_SQL_ADMIN_PASSWORD=your-admin-password
AZURE_SQL_PORT=1433
